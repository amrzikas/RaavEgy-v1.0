rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to verify if the user is the recorded admin
    function isAdmin(request) {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admin_config/setup) &&
        request.auth.uid == get(/databases/$(database)/documents/admin_config/setup).data.adminUid;
    }

    // Products
    match /products2/{productId} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    // Orders
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin(request) || (request.auth != null && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin(request);
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin(request);
    }

    // Shipping Plans
    match /shipping_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    // Settings (loyalty, payment)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin(request);
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin(request));
    }

    // Notifications
    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin(request));
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin(request));
    }

    // Conversations & Messages
    match /conversations/{convId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && (resource.data.customerId == request.auth.uid || isAdmin(request));
      
      match /messages/{msgId} {
        allow read, create: if request.auth != null;
        allow update, delete: if isAdmin(request);
      }
    }

    // Admin Config Setup
    match /admin_config/setup {
      // Allow read to anyone to check if initialized
      allow read: if true;
      // Allow create only if setup doesn't already exist
      allow create: if !exists(/databases/$(database)/documents/admin_config/setup);
      // Allow update only by the admin itself
      allow update: if request.auth != null && request.auth.uid == resource.data.adminUid;
    }
  }
}
